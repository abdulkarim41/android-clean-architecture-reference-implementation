<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="LoadingButton">
        <attr name="text" format="string" />
        <attr name="textAllCaps" format="boolean" />
        <attr name="loading" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="BaseTextView">

        <!-- Shape -->
        <attr name="tvCornerRadius" format="dimension"/>
        <attr name="tvBackgroundColor" format="color"/>

        <!-- Stroke -->
        <attr name="tvStrokeColor" format="color"/>
        <attr name="tvStrokeWidth" format="dimension"/>

    </declare-styleable>

</resources>