<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_14sdp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.abdulkarim.customview.button.LoadingButton
        style="@style/DS.Button.Filled.Rounded"
        android:id="@+id/btnSubmit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Carts Fragment"
        android:padding="@dimen/padding_14sdp"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="@color/white"/>

    <com.abdulkarim.customview.textview.TextRegular
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Regular Text"
        app:tvBackgroundColor="@color/colorPrimary"
        android:textColor="@color/white"
        android:padding="@dimen/padding_7sdp"
        app:tvCornerRadius="@dimen/radius_7sdp"/>

    <com.abdulkarim.customview.textview.TextMedium
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medium Text"
        app:tvBackgroundColor="@color/green"
        android:textColor="@color/white"
        android:padding="@dimen/padding_7sdp"
        app:tvCornerRadius="@dimen/radius_7sdp"/>

    <com.abdulkarim.customview.textview.TextBold
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bold Text"
        app:tvBackgroundColor="@color/purple"
        android:textColor="@color/white"
        android:padding="@dimen/padding_7sdp"/>

</LinearLayout>